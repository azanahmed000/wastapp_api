# ─── Server Configuration ───
PORT=3000
NODE_ENV=production

# ─── MongoDB Atlas (REQUIRED) ───
# Free-tier cluster: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/whatsapp-bridge?retryWrites=true&w=majority

# ─── API Security (REQUIRED) ───
# Secret key for protecting the /send-message endpoint.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_API_KEY=your-secret-api-key-here

# ─── WhatsApp Configuration ───
DEFAULT_COUNTRY_CODE=92

# ─── Heartbeat ───
HEARTBEAT_INTERVAL_MS=15000

# ─── Chrome Path (optional — auto-detected in Docker) ───
# CHROME_PATH=/usr/bin/chromium
